#!/usr/bin/env zsh

emulate -L zsh
setopt pipefail

function usage() {
	print -u2 "Usage: wt try <github-pr-url|branch> [-- <opencode-args>...]"
}

target="$1"

if [[ -z "$target" ]]; then
	usage
	exit 1
fi

shift
fetch_branch="$target"
fetched_commit=""
pr_shortcut=""

case "$target" in
	https://github.com/*/pull/*|http://github.com/*/pull/*|github.com/*/pull/*)
		pr_path=${target#https://github.com/}
		pr_path=${pr_path#http://github.com/}
		pr_path=${pr_path#github.com/}
		owner_repo=${pr_path%%/pull/*}
		pr_number=${target#*/pull/}
		pr_number=${pr_number%%[/?#]*}
		case "$pr_number" in
			''|*[!0-9]*)
				print -u2 "Could not parse GitHub PR URL: $target"
				exit 1
				;;
		esac
		pr_shortcut="pr:$pr_number"
		fetch_branch=""
		if command -v gh >/dev/null 2>&1; then
			fetch_branch=$(gh pr view "$pr_number" --repo "$owner_repo" --json headRefName --jq .headRefName 2>/dev/null)
		fi
		if [[ -n "$fetch_branch" ]]; then
			target="$fetch_branch"
		else
			target="$pr_shortcut"
		fi
		;;
esac

if [[ -n "$fetch_branch" ]]; then
	if ! git fetch origin "$fetch_branch"; then
		if [[ -n "$pr_shortcut" ]]; then
			print -u2 "Could not fetch origin $fetch_branch; falling back to $pr_shortcut"
			target="$pr_shortcut"
		else
			exit 1
		fi
	else
		fetched_commit=$(git rev-parse --verify "FETCH_HEAD^{commit}") || exit $?
	fi
fi

prepare_args=(--prepare)
if [[ -n "$fetched_commit" ]]; then
	prepare_args+=(--start-point "$fetched_commit" --upstream "origin/$fetch_branch")
fi
prepare_args+=("$target")

wt-prewarm "${prepare_args[@]}" || exit $?

wt switch "$target" -x opencode -- "$@"
