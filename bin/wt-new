#!/usr/bin/env zsh

emulate -L zsh
setopt pipefail

function usage() {
	print -u2 "Usage: wt new [--from <base>] [--update] [--reuse-existing] [--worktree-path <path>] [--print] <branch-name>"
}

function configure_worktree_path() {
	local requested_path="$1"
	local source_config="${WORKTRUNK_CONFIG_PATH:-$HOME/.config/worktrunk/config.toml}"

	if [[ ! -f "$source_config" ]]; then
		print -u2 "Worktrunk config not found: $source_config"
		return 1
	fi

	temporary_config=$(mktemp "${TMPDIR:-/tmp}/wt-new.XXXXXX.toml") || return 1
	awk -v path="$requested_path" '
		BEGIN {
			print "worktree-path = \"" path "\""
			replaced = 0
		}
		!replaced && $0 ~ /^worktree-path[[:space:]]*=/ {
			replaced = 1
			next
		}
		{ print }
	' "$source_config" > "$temporary_config" || return 1

	export WORKTRUNK_CONFIG_PATH="$temporary_config"
	export WT_NEW_SOURCE_CONFIG="$source_config"
	export WT_NEW_WORKTREE_PATH="$requested_path"
}

function branch_exists() {
	git show-ref --verify --quiet "refs/heads/$1"
}

function resolve_branch_name() {
	local input="$1"
	local branch_name

	if command -v wt-resolve-new-branch-name >/dev/null 2>&1; then
		branch_name=$(wt-resolve-new-branch-name "$input") || return $?
	else
		branch_name="$input"
	fi

	if [[ -z "$branch_name" ]]; then
		print -u2 "Resolved branch name is empty"
		return 1
	fi

	print -r -- "$branch_name"
}

function ticket_from_branch_name() {
	local branch_name="$1"
	local ticket

	if [[ "$branch_name" =~ '^[A-Z][A-Z0-9]+-[0-9]+$' ]]; then
		print -r -- "$branch_name"
		return 0
	fi

	ticket=$(print -r -- "$branch_name" | sed -nE 's/.*__([A-Za-z][A-Za-z0-9]*-[0-9]+)__.*/\1/p')
	[[ -n "$ticket" ]] || return 1
	print -r -- "${ticket:u}"
}

function rename_terminal_tab_for_ticket() {
	local branch_name="$1"
	local ticket target

	ticket=$(ticket_from_branch_name "$branch_name") || return 0

	if [[ -n "${HERDR_WORKSPACE_ID:-}" ]] && command -v herdr >/dev/null 2>&1; then
		herdr workspace rename "$HERDR_WORKSPACE_ID" " ${ticket}" >/dev/null 2>&1 || true
	fi

	if [[ -n "${HERDR_TAB_ID:-}" ]] && command -v herdr >/dev/null 2>&1; then
		herdr tab rename "$HERDR_TAB_ID" "$ticket" >/dev/null 2>&1 || true
		return 0
	fi

	[[ -n "${TMUX:-}" ]] || return 0
	command -v tmux >/dev/null 2>&1 || return 0
	target=$(tmux display-message -p -t "${TMUX_PANE:-}" '#{window_id}' 2>/dev/null) || return 0

	tmux rename-window -t "$target" "$ticket" >/dev/null 2>&1 || true
}

print_only=0
update_after_create=0
reuse_existing=0
base_branch=""
worktree_path=""
temporary_config=""

trap '[[ -n "$temporary_config" ]] && rm -f "$temporary_config"' EXIT

while [[ $# -gt 0 ]]; do
	case "$1" in
		--print)
			print_only=1
			shift
			;;
		--update)
			update_after_create=1
			shift
			;;
		--reuse-existing)
			reuse_existing=1
			shift
			;;
		--worktree-path)
			shift
			if [[ -z "$1" ]]; then
				usage
				exit 1
			fi
			worktree_path="$1"
			shift
			;;
		--from)
			shift
			if [[ -z "$1" ]]; then
				usage
				exit 1
			fi
			base_branch="$1"
			shift
			;;
		--)
			shift
			break
			;;
		-*)
			print -u2 "Unknown option for wt new: $1"
			exit 1
			;;
		*)
			break
			;;
	esac
done

if [[ $# -ne 1 ]]; then
	usage
	exit 1
fi

branch_name=$(resolve_branch_name "$1") || exit $?

if [[ "$print_only" -eq 1 ]]; then
	print -r -- "$branch_name"
	exit 0
fi

if [[ -n "$worktree_path" ]]; then
	configure_worktree_path "$worktree_path" || exit $?
fi

if [[ "$reuse_existing" -eq 1 ]] && branch_exists "$branch_name"; then
	wt switch "$branch_name" || exit $?
	rename_terminal_tab_for_ticket "$branch_name"
	exit 0
fi

prepare_args=(prepare --create)
if [[ -n "$base_branch" ]]; then
	prepare_args+=(--base "$base_branch")
fi
if [[ "$update_after_create" -eq 1 ]]; then
	prepare_args+=(--update)
fi
prepare_args+=("$branch_name")

wt-prewarm "${prepare_args[@]}" || exit $?

wt switch "$branch_name"
rename_terminal_tab_for_ticket "$branch_name"
