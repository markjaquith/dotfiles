#!/usr/bin/env zsh

emulate -L zsh
setopt pipefail

# Maintain a prewarmed worktree so `wt new <branch>` and `wt try <branch>` can
# claim it instead of paying for a full checkout. The prewarm's existence is the
# opt-in signal: callers only take the fast path — and only re-arm a prewarm
# afterward — when one already exists. Arm it by running `wt prewarm` (alias for
# this script).

PREWARM_BRANCH="${WT_PREWARM_BRANCH:-worktrunk-prewarm}"
MARKER=".wt-prewarm-ready"

function usage() {
	print -r -- "Usage: wt-prewarm [command] [options]"
	print -r -- ""
	print -r -- "Maintains a prewarmed worktree on branch '${PREWARM_BRANCH}'."
	print -r -- ""
	print -r -- "Commands:"
	print -r -- "  ensure            Create the prewarm if missing/incomplete (default)"
	print -r -- "  rebuild           Remove and recreate from the default branch tip"
	print -r -- "  remove            Remove the prewarm worktree and branch"
	print -r -- "  status            Report prewarm state"
	print -r -- "  prepare [--create] [--base <base>] [--start-point <commit>]"
	print -r -- "          [--upstream <ref>] [--update] <branch>"
	print -r -- "                    Prepare a worktree, claiming a prewarm when possible"
	print -r -- "  update <branch>   Fast-forward <branch>'s worktree to the prewarm base"
	print -r -- "  help              Show this help"
}

function die() {
	print -u2 -- "wt-prewarm: $*"
	exit 1
}

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "not inside a git repository"

function branch_exists() {
	git show-ref --verify --quiet "refs/heads/$1"
}

function worktree_path_for_branch() {
	local target_branch="$1"
	local worktree_path

	git worktree list --porcelain | while IFS= read -r line; do
		if [[ "$line" == worktree\ * ]]; then
			worktree_path="${line#worktree }"
			continue
		fi

		if [[ "$line" == "branch refs/heads/${target_branch}" ]]; then
			print -r -- "$worktree_path"
			return 0
		fi
	done
}

function default_branch() {
	local d c

	if d=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null); then
		print -r -- "${d#origin/}"
		return 0
	fi

	for c in main master; do
		if branch_exists "$c"; then
			print -r -- "$c"
			return 0
		fi
	done

	git rev-parse --abbrev-ref HEAD
}

function lock_path() {
	local gcd
	gcd=$(git rev-parse --git-common-dir 2>/dev/null) || return 1
	[[ "$gcd" == /* ]] || gcd="${PWD}/${gcd}"
	print -r -- "${gcd%/}/wt-prewarm.lock"
}

function acquire_lock() {
	local lock="$1"
	local mt now

	if mkdir "$lock" 2>/dev/null; then
		return 0
	fi

	# Stale-lock breaker: reclaim a lock older than 5 minutes.
	mt=$(stat -f %m "$lock" 2>/dev/null) || mt=$(stat -c %Y "$lock" 2>/dev/null)
	now=$(date +%s)
	if [[ -n "$mt" ]] && (( now - mt > 300 )); then
		rmdir "$lock" 2>/dev/null
		mkdir "$lock" 2>/dev/null && return 0
	fi

	return 1
}

function release_lock() {
	[[ -n "$1" ]] && rmdir "$1" 2>/dev/null
	return 0
}

function remove_prewarm() {
	local pw
	pw=$(worktree_path_for_branch "$PREWARM_BRANCH" 2>/dev/null)
	if [[ -n "$pw" ]]; then
		git worktree remove --force "$pw" 2>/dev/null
	fi
	git worktree prune 2>/dev/null
	if branch_exists "$PREWARM_BRANCH"; then
		git branch -D "$PREWARM_BRANCH" 2>/dev/null
	fi
}

function build_prewarm() {
	local base pw

	base=$(default_branch) || return 1

	# Clean slate so the prewarm always starts from the current default tip.
	remove_prewarm

	# Build with --no-hooks: the prewarm is a bare checkout of the default tip.
	# Hooks must run against the *claiming* branch at its final path, not against
	# "$PREWARM_BRANCH" at the prewarm path (zoxide/mise trust are path-keyed,
	# and branch-derived templates would resolve to the wrong branch), so the
	# claim side runs them after the move.
	wt -y switch --create --no-cd --no-hooks --base "$base" "$PREWARM_BRANCH" || return 1

	pw=$(worktree_path_for_branch "$PREWARM_BRANCH" 2>/dev/null)
	[[ -n "$pw" ]] || return 1

	# The marker means the expensive checkout is complete. Because the build runs
	# no hooks, there is no background install that a claim could move out from
	# under, so marker-present truly means claimable.
	touch "${pw}/${MARKER}"
	print -r -- "wt-prewarm: ready at ${pw} (branch ${PREWARM_BRANCH}, base ${base})"
}

# Claim the prewarmed worktree instead of paying for a full checkout. Returns 0
# on success (worktree now exists on "$branch_name"), non-zero to signal the
# caller should fall back to the slow path. A start point lets callers such as
# `wt try` reuse the checkout for an existing remote branch; without one, the
# branch remains at the prewarm's default-branch commit for `wt new`. Any failure
# rolls back to a clean prewarm before returning non-zero.
function claim_prewarm() {
	local branch_name="$1"
	local start_point="$2"
	local upstream="$3"
	local pw_path parent pw_base prewarm_sanitized branch_sanitized target_path lock
	local prewarm_head target_commit

	[[ -n "$branch_name" ]] || die "claim requires a branch name"

	# The destination branch must not already exist. Cheap single git show-ref
	# gate, kept before the lock so an obviously-doomed claim never contends.
	branch_exists "$branch_name" && return 1

	# Acquire the lock before enumerating worktrees so the listing below is the
	# single authoritative read for this claim: there is no separate pre-lock
	# `git worktree list`, and nothing can race the prewarm out from under us
	# between validation and the rename/move.
	lock=$(lock_path) || return 1
	acquire_lock "$lock" || return 1

	# A ready prewarm worktree (checkout complete) must exist. This is the only
	# worktree enumeration in the claim path.
	pw_path=$(worktree_path_for_branch "$PREWARM_BRANCH" 2>/dev/null)
	if [[ -z "$pw_path" || ! -d "$pw_path" || ! -f "${pw_path}/${MARKER}" ]]; then
		release_lock "$lock"
		return 1
	fi

	# Only support worktree-path templates whose final component is the
	# sanitized branch name (e.g. ".../{{ branch | sanitize }}"). For any other
	# template shape the computed target would be wrong, so fall back.
	parent="${pw_path:h}"
	pw_base="${pw_path:t}"
	prewarm_sanitized="${PREWARM_BRANCH//[\/\\]/-}"
	branch_sanitized="${branch_name//[\/\\]/-}"
	target_path="${parent}/${branch_sanitized}"
	if [[ "$pw_base" != "$prewarm_sanitized" || -e "$target_path" ]]; then
		release_lock "$lock"
		return 1
	fi

	# Drop the readiness marker so it does not travel into the new worktree.
	rm -f "${pw_path}/${MARKER}" 2>/dev/null
	prewarm_head=$(git rev-parse --verify "${PREWARM_BRANCH}^{commit}" 2>/dev/null)
	if [[ -z "$prewarm_head" ]]; then
		touch "${pw_path}/${MARKER}" 2>/dev/null
		release_lock "$lock"
		return 1
	fi

	# A fetched branch can reuse the prewarm checkout by updating only the files
	# that differ from the default branch. Do this before the rename and hooks so
	# every lifecycle hook observes the requested commit at the final path.
	if [[ -n "$start_point" ]]; then
		target_commit=$(git rev-parse --verify "${start_point}^{commit}" 2>/dev/null)
		if [[ -z "$target_commit" ]] || ! git -C "$pw_path" reset --hard "$target_commit" >/dev/null 2>&1; then
			git -C "$pw_path" reset --hard "$prewarm_head" >/dev/null 2>&1
			touch "${pw_path}/${MARKER}" 2>/dev/null
			release_lock "$lock"
			return 1
		fi
	fi

	# Rename the branch in place (instant).
	if ! git branch -m "$PREWARM_BRANCH" "$branch_name" 2>/dev/null; then
		git -C "$pw_path" reset --hard "$prewarm_head" >/dev/null 2>&1
		touch "${pw_path}/${MARKER}" 2>/dev/null
		release_lock "$lock"
		return 1
	fi

	# Move the worktree directory to its template path (same-filesystem rename).
	if ! git worktree move "$pw_path" "$target_path" 2>/dev/null; then
		# Roll back the rename; the worktree is still at pw_path on branch_name.
		if git branch -m "$branch_name" "$PREWARM_BRANCH" 2>/dev/null; then
			git -C "$pw_path" reset --hard "$prewarm_head" >/dev/null 2>&1
			touch "${pw_path}/${MARKER}" 2>/dev/null
		fi
		release_lock "$lock"
		return 1
	fi

	if [[ -n "$upstream" ]]; then
		git -C "$target_path" branch --set-upstream-to="$upstream" "$branch_name" >/dev/null 2>&1 \
			|| print -u2 -- "wt-prewarm: could not set ${branch_name} to track ${upstream} (continuing)"
	fi

	release_lock "$lock"

	# The claim bypassed the normal Worktrunk switch/create path, so none of its
	# hooks have run for "$branch_name". Run them now against the
	# claimed worktree at its final path so behavior matches the slow path
	# (`wt switch --create`). These must target the real branch/path — the
	# prewarm build runs with --no-hooks precisely so path-keyed and
	# branch-derived hooks resolve here, not against the prewarm branch.
	# Best-effort: the worktree already exists, so a hook failure must not fail
	# the claim.
	#
	# Each `wt hook` invocation costs ~1.25s of worktrunk startup, and worktrunk
	# already self-backgrounds the actual install work. Only pre-start
	# (e.g. mise trust) is a documented "blocks" hook, so it stays synchronous;
	# the post-switch/post-start phases are detached into a single background
	# subshell (run sequentially there so post-start still follows post-switch)
	# so the claim message prints ~2.5s sooner. The caller's final `wt switch`
	# re-runs post-switch idempotently, so a slight overlap here is harmless.
	wt -C "$target_path" -y hook pre-start </dev/null >/dev/null 2>&1 \
		|| print -u2 -- "wt-prewarm: pre-start hooks failed for ${branch_name} (continuing)"

	(
		wt -C "$target_path" -y hook post-switch </dev/null >/dev/null 2>&1
		wt -C "$target_path" -y hook post-start </dev/null >/dev/null 2>&1
	) &
	disown 2>/dev/null

	# Rebuild the prewarm in the background for next time (fully detached).
	( wt-prewarm rebuild </dev/null >/dev/null 2>&1 & )

	print -u2 -- "wt-prewarm: claimed prewarm → ${branch_name}"
	return 0
}

# Prepare a worktree, using a ready prewarm when its inputs make that safe.
# --create prepares a new branch for `wt new`; without it, an existing fetched
# branch is prepared for `wt try`. The slow path delegates to `wt switch` so
# normal Worktrunk creation behavior remains the source of truth.
function prepare_worktree() {
	local create_branch=0
	local update_after_create=0
	local base_branch=""
	local start_point=""
	local upstream=""
	local branch_name
	local claimed=0
	local -a switch_args

	while [[ $# -gt 0 ]]; do
		case "$1" in
			--create)
				create_branch=1
				shift
				;;
			--base)
				shift
				[[ -n "$1" ]] || die "prepare --base requires a branch"
				base_branch="$1"
				shift
				;;
			--start-point)
				shift
				[[ -n "$1" ]] || die "prepare --start-point requires a commit"
				start_point="$1"
				shift
				;;
			--upstream)
				shift
				[[ -n "$1" ]] || die "prepare --upstream requires a ref"
				upstream="$1"
				shift
				;;
			--update)
				update_after_create=1
				shift
				;;
			--)
				shift
				break
				;;
			-*)
				die "unknown prepare option: $1"
				;;
			*)
				break
				;;
		esac
	done

	[[ $# -eq 1 ]] || die "prepare requires exactly one branch"
	branch_name="$1"

	if (( create_branch )); then
		[[ -z "$start_point" && -z "$upstream" ]] \
			|| die "prepare --create cannot use --start-point or --upstream"
	else
		[[ -z "$base_branch" && "$update_after_create" -eq 0 ]] \
			|| die "prepare requires --create with --base or --update"
		[[ -z "$upstream" || -n "$start_point" ]] \
			|| die "prepare --upstream requires --start-point"
	fi

	if (( create_branch )) && [[ -z "$base_branch" ]]; then
		claim_prewarm "$branch_name" && claimed=1
	elif (( ! create_branch )) && [[ -n "$start_point" ]]; then
		claim_prewarm "$branch_name" "$start_point" "$upstream" && claimed=1
	fi

	if (( ! claimed )); then
		switch_args=(switch --no-cd)
		if (( create_branch )); then
			switch_args+=(--create)
		fi
		if [[ -n "$base_branch" ]]; then
			switch_args+=(--base "$base_branch")
		fi
		switch_args+=("$branch_name")

		wt "${switch_args[@]}" || return $?
	fi

	if (( update_after_create )) && [[ -z "$base_branch" ]]; then
		update_branch "$branch_name"
	fi
}

# Bring <branch>'s worktree up to speed with the LOCAL tip of the prewarm base
# branch (the same default branch the prewarm was built from). There is no
# fetch — the caller owns remote freshness. This is best-effort: a fast-forward
# keeps history clean and only succeeds when <branch> hasn't diverged from the
# base (the expected case for a freshly created or just-claimed prewarm branch).
# If it cannot fast-forward, report it and still return 0 so `wt new` continues;
# the branch is simply left at its current (older) tip and the user is told.
function update_branch() {
	local branch_name="$1"
	local base wt_path

	[[ -n "$branch_name" ]] || die "update requires a branch name"

	base=$(default_branch) || return 0

	# Nothing to integrate if the branch is the base branch itself.
	[[ "$base" == "$branch_name" ]] && return 0

	wt_path=$(worktree_path_for_branch "$branch_name" 2>/dev/null)
	if [[ -z "$wt_path" || ! -d "$wt_path" ]]; then
		print -u2 -- "wt-prewarm: no worktree found for ${branch_name}; skipping update"
		return 0
	fi

	if git -C "$wt_path" merge --ff-only "$base" >/dev/null 2>&1; then
		print -u2 -- "wt-prewarm: ${branch_name} is up to date with ${base}"
		return 0
	fi

	print -u2 -- "wt-prewarm: could not fast-forward ${branch_name} to ${base}; leaving it as-is (not up to date with ${base})"
	return 0
}

command_name="${1:-ensure}"
if [[ $# -gt 0 ]]; then
	shift
fi

case "$command_name" in
	-h|--help|help)
		usage
		exit 0
		;;
	status)
		[[ $# -eq 0 ]] || die "status does not accept arguments"
		pw=$(worktree_path_for_branch "$PREWARM_BRANCH" 2>/dev/null)
		if [[ -n "$pw" && -d "$pw" ]]; then
			if [[ -f "${pw}/${MARKER}" ]]; then
				print -r -- "ready: ${pw}"
			else
				print -r -- "building (no marker yet): ${pw}"
			fi
		elif branch_exists "$PREWARM_BRANCH"; then
			print -r -- "branch '${PREWARM_BRANCH}' exists but has no worktree"
		else
			print -r -- "absent"
		fi
		exit 0
		;;
	remove)
		[[ $# -eq 0 ]] || die "remove does not accept arguments"
		lock=$(lock_path) || die "could not resolve lock path"
		acquire_lock "$lock" || die "another wt-prewarm operation is in progress"
		remove_prewarm
		release_lock "$lock"
		print -r -- "wt-prewarm: removed"
		exit 0
		;;
	prepare)
		prepare_worktree "$@"
		exit $?
		;;
	update)
		[[ $# -eq 1 ]] || die "update requires exactly one branch"
		update_branch "$1"
		exit $?
		;;
	rebuild)
		[[ $# -eq 0 ]] || die "rebuild does not accept arguments"
		lock=$(lock_path) || die "could not resolve lock path"
		# If a rebuild is already running, do nothing.
		acquire_lock "$lock" || exit 0
		build_prewarm
		rc=$?
		release_lock "$lock"
		exit $rc
		;;
	ensure)
		[[ $# -eq 0 ]] || die "ensure does not accept arguments"
		lock=$(lock_path) || die "could not resolve lock path"
		acquire_lock "$lock" || exit 0
		pw=$(worktree_path_for_branch "$PREWARM_BRANCH" 2>/dev/null)
		if [[ -n "$pw" && -f "${pw}/${MARKER}" ]]; then
			release_lock "$lock"
			print -r -- "wt-prewarm: already ready at ${pw}"
			exit 0
		fi
		build_prewarm
		rc=$?
		release_lock "$lock"
		exit $rc
		;;
	*)
		usage
		exit 1
		;;
esac
