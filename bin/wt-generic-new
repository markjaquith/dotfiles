#!/usr/bin/env zsh

# Clean reference implementation of the worktrunk prewarm integration.
#
# This is the shareable counterpart to bin/wt-new: it shows how to wire up
# `wt-prewarm` with zero local opinions (no agency, jira, or tmux logic). It
# creates a new worktree for <branch-name>, claiming a prewarmed worktree for
# an instant result when one is armed, and otherwise falling back to a normal
# `wt switch --create`.
#
# Arm a prewarm with `wt prewarm` (alias for bin/wt-prewarm); `--prepare`
# handles both the fast claim and normal Worktrunk fallback paths.

emulate -L zsh
setopt pipefail

function usage() {
	print -u2 "Usage: wt generic-new [--from <base>] [--update] [--print] <branch-name>"
}

print_only=0
update_after_create=0
base_branch=""

while [[ $# -gt 0 ]]; do
	case "$1" in
		--print)
			print_only=1
			shift
			;;
		--update)
			update_after_create=1
			shift
			;;
		--from)
			shift
			if [[ -z "$1" ]]; then
				usage
				exit 1
			fi
			base_branch="$1"
			shift
			;;
		--)
			shift
			break
			;;
		-*)
			print -u2 "Unknown option for wt generic-new: $1"
			exit 1
			;;
		*)
			break
			;;
	esac
done

if [[ $# -ne 1 ]]; then
	usage
	exit 1
fi

branch_name="$1"

if [[ "$print_only" -eq 1 ]]; then
	print -r -- "$branch_name"
	exit 0
fi

prepare_args=(--prepare --create)
if [[ -n "$base_branch" ]]; then
	prepare_args+=(--base "$base_branch")
fi
if [[ "$update_after_create" -eq 1 ]]; then
	prepare_args+=(--update)
fi
prepare_args+=("$branch_name")

wt-prewarm "${prepare_args[@]}" || exit $?

wt switch "$branch_name"
