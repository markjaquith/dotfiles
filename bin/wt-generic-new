#!/usr/bin/env zsh

# Clean reference implementation of the worktrunk prewarm integration.
#
# This is the shareable counterpart to bin/wt-new: it shows how to wire up
# `wt-prewarm` with zero local opinions (no agency, jira, or tmux logic). It
# creates a new worktree for <branch-name>, claiming a prewarmed worktree for
# an instant result when one is armed, and otherwise falling back to a normal
# `wt switch --create`.
#
# Arm a prewarm with `wt prewarm` (alias for bin/wt-prewarm). See bin/wt-prewarm
# (--claim) for the fast-path implementation that this script delegates to.

emulate -L zsh
setopt pipefail

function usage() {
	print -u2 "Usage: wt generic-new [--from <base>] [--print] <branch-name>"
}

print_only=0
base_branch=""

while [[ $# -gt 0 ]]; do
	case "$1" in
		--print)
			print_only=1
			shift
			;;
		--from)
			shift
			if [[ -z "$1" ]]; then
				usage
				exit 1
			fi
			base_branch="$1"
			shift
			;;
		--)
			shift
			break
			;;
		-*)
			print -u2 "Unknown option for wt generic-new: $1"
			exit 1
			;;
		*)
			break
			;;
	esac
done

if [[ $# -ne 1 ]]; then
	usage
	exit 1
fi

branch_name="$1"

if [[ "$print_only" -eq 1 ]]; then
	print -r -- "$branch_name"
	exit 0
fi

created_fast=0
# Whether a prewarm exists is the only opt-in signal: `wt-prewarm --claim`
# returns non-zero (and we fall back to the slow path) unless a ready prewarm
# worktree is present. The prewarm is always built from the default base, so it
# can only be claimed when no explicit --base was requested.
if [[ -z "$base_branch" ]]; then
	if wt-prewarm --claim "$branch_name"; then
		created_fast=1
	fi
fi

if [[ "$created_fast" -eq 0 ]]; then
	args=(switch --create --no-cd)
	if [[ -n "$base_branch" ]]; then
		args+=(--base "$base_branch")
	fi
	args+=("$branch_name")

	wt "${args[@]}" || exit $?
fi

wt switch "$branch_name"
