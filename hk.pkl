amends "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Config.pkl"

local linters = new Mapping<String, Step> {
	["oxfmt"] {
		glob = List("*.js", "*.jsx", "*.mjs", "*.cjs", "*.ts", "*.tsx", "*.mts", "*.cts", "*.css", "*.scss", "*.less", "*.html", "*.json", "*.json5", "*.jsonc", "*.yaml", "*.yml", "*.md", "*.graphql", "*.svelte", "*.astro", "*.vue")
		exclude = List(".config/opencode/package.json", ".config/opencode/package-lock.json")
		check = "oxfmt --check {{ files }}"
		fix = "oxfmt --write {{ files }}"
	}

	// Custom linter for pkl files
	["pkl"] {
		glob = "*.pkl"
		check = "pkl eval {{files}} >/dev/null"
	}

	["content-scan"] {
		check = "if [ -n \"{{files}}\" ]; then bunx secretlint {{files}}; fi"
	}

	["zsh-tests"] {
		check = "zsh test/open-tmux-urls.test.zsh"
	}
}

hooks {
	["pre-commit"] {
		fix = true
		stash = "patch-file"
		steps = linters
	}

	["pre-push"] {
		fix = false
		steps = linters
	}

	["fix"] {
		fix = true
		steps = linters
	}

	["check"] {
		steps = linters
	}
}
