{
	"$schema": "https://opencode.ai/config.json",
	"plugin": ["opencode-queue@0.11.2"],
	"snapshot": false,
	"mcp": {
		"playwright": {
			"type": "local",
			"command": ["npx", "-y", "@playwright/mcp@latest"],
			"enabled": true,
		},
	},
	"permission": {
		"read": {
			"~/.local/share/mise/installs/**": "allow",
		},
		"edit": {
			"~/worktrees/**": "allow",
		},
		"external_directory": {
			"/Users/mark.jaquith/.crit/**": "allow",
			"/Users/mark/.crit/**": "allow",
			"~/worktrees/**": "allow",
		},
	},
}
